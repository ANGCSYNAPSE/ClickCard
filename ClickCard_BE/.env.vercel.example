NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

JWT_SECRET=replace_with_a_strong_random_secret
JWT_EXPIRE=45m
REFRESH_TOKEN_SECRET=replace_with_a_different_strong_random_secret
REFRESH_TOKEN_EXPIRE=7d

BASE_URL=https://click-card-be.vercel.app
SHARE_LINK_BASE_URL=https://click-card-be.vercel.app
FRONTEND_URL=https://your-frontend-domain.com

EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=ClickCard <your-gmail-address@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

OTP_EXPIRY=10
OTP_LENGTH=6

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
