# ── ClickCard web environment ──────────────────────────────────────────────
# Backend base URL. Defaults to the deployed API if unset.
NEXT_PUBLIC_API_BASE_URL=https://click-card-be.vercel.app

# Public base used when rendering share-link short URLs / QR codes.
NEXT_PUBLIC_SHARE_BASE=https://clickcard.app/s

# Marketing-site origin — where public profiles (/username) are hosted.
# "View public page" links point here.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
