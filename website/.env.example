# ── ClickCard marketing website ────────────────────────────────────────────
# URL of the ClickCard web app (portal). "Log in" / "Get started" buttons go here.
NEXT_PUBLIC_WEB_URL=http://localhost:3001

# This site's own public URL — used to build share URLs / canonical / OG tags
# for public profile pages at /[slug].
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend base URL — used server-side to fetch public profiles for /[slug].
NEXT_PUBLIC_API_BASE_URL=https://click-card-be.vercel.app
